---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";

const {
  image,
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  includeSidebar = true,
  sideBarActiveItemID,
  ogType,
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      ,
      ogType={ogType}
    />
    {TRANSITION_API && <ViewTransitions />}
    <script is:inline>
      (() => {
        const storageKey = "theme";
        const defaultTheme = "dark";
        const getTheme = () => localStorage.getItem(storageKey) || defaultTheme;

        const applyTheme = (targetDocument = document) => {
          const theme = getTheme();
          targetDocument.documentElement.setAttribute("data-theme", theme);
          targetDocument.querySelectorAll(".theme-controller").forEach((controller) => {
            controller.checked = theme === controller.value;
          });
        };

        applyTheme();

        if (window.__anhBuiThemePersistenceInitialized) {
          return;
        }

        window.__anhBuiThemePersistenceInitialized = true;

        document.addEventListener("change", (event) => {
          const controller = event.target.closest?.(".theme-controller");
          if (!controller) {
            return;
          }

          localStorage.setItem(
            storageKey,
            controller.checked ? controller.value : defaultTheme,
          );
          applyTheme();
        });

        document.addEventListener("astro:before-swap", (event) => {
          applyTheme(event.newDocument);
        });

        document.addEventListener("astro:page-load", () => {
          applyTheme();
        });

        document.addEventListener("DOMContentLoaded", () => {
          applyTheme();
        });
      })();
    </script>
  </head>
  <body>
    <div class="bg-base-100 min-h-screen flex flex-col">
      <Header title={SITE_TITLE} />
      <div class="md:flex md:justify-center">
        <main class="w-full max-w-[1200px] p-6 pt-10">
          <slot />
        </main>
      </div>
      <Footer />
    </div>
  </body>
</html>
