---
import BaseLayout from "../layouts/BaseLayout.astro";

const proofPoints = [
  {
    value: "20+",
    label: "Years in software",
    detail: "From long-lived enterprise platforms to modern cloud services.",
  },
  {
    value: "8",
    label: "Years leading teams",
    detail: "Development lead, technical lead, Scrum Master, and project management.",
  },
  {
    value: "8",
    label: "Live SaaS products",
    detail: "Browser software actively available to real users.",
  },
  {
    value: "RCA",
    label: "Root-cause mindset",
    detail: "Tracing failures through code, config, data, version history, and live behaviour.",
  },
  {
    value: "AI",
    label: "Agentic workflow",
    detail: "Claude Code, MCP, custom skills, hooks, memory, and automation.",
  },
];

const aboutFocus = [
  "Senior .NET delivery: more than two decades building, maintaining, and improving production business systems.",
  "Broad domain range: financial services, automotive dealer management, healthcare, e-payment, housing, communications, insurance, and manufacturing.",
  "Root cause over quick fix: I follow evidence to the actual source instead of patching what is visible.",
  "Modernisation with stability: I bridge legacy VB6 and long-lived .NET systems with modern services while keeping production dependable.",
  "Agentic AI development: I use Claude Code and MCP daily on real production code for navigation, debugging, refactoring, QA, and team workflow automation.",
  "Product ownership: I design, build, operate, license, release, and support my own SaaS products for real users.",
];

const workWith = [
  {
    title: "Backend & APIs",
    description:
      "C#, .NET Framework / .NET, ASP.NET Core, Web API, WCF/SOAP services, WinForms, Entity Framework, and dependency injection.",
  },
  {
    title: "Financial systems & data",
    description:
      "Lending and collections platforms, fintech and payment flows, SQL Server, T-SQL, audit trails, schema analysis, and query debugging.",
  },
  {
    title: "Cloud & config",
    description:
      "Azure App Services, Functions, Queue Storage, Azure SQL, Key Vault, Application Insights, Azure App Config, OAuth, and environment management.",
  },
  {
    title: "Security, workflow & products",
    description:
      "Application-layer encryption, credential handling, Git, Azure DevOps, PowerShell, Chrome and Edge extensions, Claude Code, and MCP.",
  },
  {
    title: "AI-assisted development",
    description:
      "Claude Code, MCP server setup, custom skills and commands, hooks, context and memory engineering, prompt design, QA, and PowerShell automation.",
  },
];

const capabilities = [
  {
    title: "Fintech & payments",
    description:
      "Hosted checkout, tokenisation, callbacks, reconciliation, auditability, and third-party provider integrations.",
  },
  {
    title: "Azure cloud",
    description:
      "Cloud services designed for visibility, reliability, security, and day-to-day operation.",
  },
  {
    title: "Legacy modernisation",
    description:
      "Incremental improvement of long-lived systems without losing operational stability.",
  },
  {
    title: "Root-cause debugging",
    description:
      "Code paths, SQL, configuration, logs, version history, and live behaviour traced together.",
  },
  {
    title: "Product engineering",
    description:
      "End-to-end SaaS ownership across UX, licensing, release management, privacy, and support.",
  },
  {
    title: "Technical leadership",
    description:
      "Code review, mentoring, pragmatic architecture, engineering management, and delivery ownership.",
  },
  {
    title: "Agentic AI workflow",
    description:
      "Daily AI-assisted work on production code, with human review, testing, and real-system verification kept central.",
  },
];
---

<BaseLayout
  title="Anh Bui | Senior .NET Software Engineer"
  description="Senior .NET software engineer with 20+ years of experience across financial systems, Azure cloud services, integrations, legacy modernisation, SaaS products, SQL Server, root-cause debugging, and AI-assisted development."
  sideBarActiveItemID="home"
>
  <section class="grid grid-cols-1 gap-10 pb-12 pt-4 md:grid-cols-12 md:items-center md:pb-16 md:pt-10">
    <div class="md:col-span-8">
      <h1 class="text-5xl font-bold tracking-tight md:text-7xl">Anh Bui</h1>
      <p class="mt-4 max-w-3xl text-2xl font-semibold leading-tight opacity-90 md:text-4xl">
        Senior / Lead Software Engineer · .NET, Azure, Financial Systems & SaaS Products
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed opacity-75">
        I build and maintain business-critical software across enterprise
        financial systems, Azure cloud services, integrations, and SaaS
        products. My work spans architecture, implementation, production
        support, legacy modernisation, and technical leadership.
      </p>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed opacity-75">
        I am strongest in large, long-lived codebases where correctness,
        auditability, and reliability matter: tracing problems through code,
        SQL, configuration, integrations, and version history until the real
        cause is clear.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/cv" class="btn btn-primary">View CV</a>
        <a href="/products" class="btn btn-outline">Explore Products</a>
      </div>
      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm opacity-65">
        <span>C# / .NET</span>
        <span>Azure</span>
        <span>Fintech & payments</span>
        <span>SQL Server</span>
        <span>SaaS products</span>
      </div>
    </div>

    <aside class="flex items-center gap-5 md:col-span-4 md:flex-col md:items-end md:text-right">
      <img
        src="/profile.png"
        alt="Anh Bui"
        class="h-28 w-28 rounded-full object-cover ring-1 ring-white/20 shadow-xl md:h-44 md:w-44"
        loading="eager"
      />
      <div>
        <div class="text-lg font-semibold">Based in the UK</div>
        <div class="mt-1 max-w-xs text-sm leading-relaxed opacity-65">
          Senior engineering depth with hands-on ownership from architecture to
          production support.
        </div>
      </div>
    </aside>
  </section>

  <section
    class="grid grid-cols-1 border-y border-base-300 md:grid-cols-5"
    aria-label="Engineering highlights"
  >
    {
      proofPoints.map((point) => (
        <article class="border-base-300 py-6 md:border-r md:px-6 md:first:pl-0 md:last:border-r-0">
          <div class="text-3xl font-bold text-primary">{point.value}</div>
          <h2 class="mt-2 font-semibold">{point.label}</h2>
          <p class="mt-2 max-w-sm text-sm leading-relaxed opacity-65">
            {point.detail}
          </p>
        </article>
      ))
    }
  </section>

  <section class="grid grid-cols-1 gap-12 border-b border-base-300 py-14 md:grid-cols-2 md:gap-16 md:py-20">
    <article>
      <div class="text-sm font-semibold uppercase tracking-widest text-primary">
        About
      </div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        Broad senior experience, sharpened by deep debugging.
      </h2>
      <p class="mt-4 leading-relaxed opacity-75">
        My career has covered hands-on engineering, senior delivery, team
        leadership, enterprise .NET platforms, financial systems, cloud services,
        partner integrations, and independent SaaS product work. The common
        thread is practical ownership: understand the system, make the right
        change, and keep it supportable.
      </p>
      <ul class="mt-6 space-y-3">
        {
          aboutFocus.map((strength) => (
            <li class="flex gap-3 text-sm leading-relaxed opacity-80">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="mt-0.5 h-5 w-5 shrink-0 fill-primary"
                aria-hidden="true"
              >
                <path d="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" />
              </svg>
              <span>{strength}</span>
            </li>
          ))
        }
      </ul>
      <a
        href="/cv"
        class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
      >
        Read the full CV
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="h-4 w-4 fill-current"
          aria-hidden="true"
        >
          <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
        </svg>
      </a>
    </article>

    <article>
      <div class="text-sm font-semibold uppercase tracking-widest text-primary">
        What I work with
      </div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        Backend, cloud, data, products, and the tooling around them.
      </h2>
      <p class="mt-4 leading-relaxed opacity-75">
        I am comfortable moving between architecture and the details: APIs,
        payment and identity flows, SQL behaviour, secure configuration, browser
        products, and automation that helps teams move faster.
      </p>
      <div class="mt-6 grid gap-5">
        {
          workWith.map((item) => (
            <section>
              <h3 class="font-semibold">{item.title}</h3>
              <p class="mt-1 text-sm leading-relaxed opacity-70">
                {item.description}
              </p>
            </section>
          ))
        }
      </div>
      <a
        href="/projects"
        class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
      >
        See related work
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="h-4 w-4 fill-current"
          aria-hidden="true"
        >
          <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
        </svg>
      </a>
    </article>
  </section>

  <section class="border-b border-base-300 py-14 md:py-16">
    <div class="max-w-3xl">
      <div class="text-sm font-semibold uppercase tracking-widest text-primary">
        Working with AI
      </div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        AI tooling is part of how I engineer, not a novelty.
      </h2>
      <p class="mt-4 leading-relaxed opacity-75">
        I use agentic coding assistants on a large production codebase for the
        work that actually takes time: navigating unfamiliar modules,
        reproducing failures, tracing root causes through code, configuration,
        SQL, and Git history, and shaping QA.
      </p>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-x-8 gap-y-7 md:grid-cols-3">
      <article>
        <h3 class="font-semibold">MCP servers</h3>
        <p class="mt-2 text-sm leading-relaxed opacity-65">
          I set up and configure Model Context Protocol servers, then diagnose
          tool behaviour, scope-gated results, and resolution paths so a team can
          rely on them.
        </p>
      </article>
      <article>
        <h3 class="font-semibold">Skills, commands & hooks</h3>
        <p class="mt-2 text-sm leading-relaxed opacity-65">
          I author reusable skills and slash-commands, wire up session hooks and
          custom modes, and use PowerShell automation to distribute shared AI
          tooling.
        </p>
      </article>
      <article>
        <h3 class="font-semibold">Context & memory engineering</h3>
        <p class="mt-2 text-sm leading-relaxed opacity-65">
          I design persistent, structured memory so findings carry between
          sessions and the assistant compounds knowledge instead of restarting.
        </p>
      </article>
    </div>
  </section>

  <section class="border-b border-base-300 py-14 md:py-16">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight">What I bring</h2>
      <p class="mt-3 leading-relaxed opacity-70">
        A mix of senior engineering judgement, production support discipline,
        root-cause investigation, cloud and integration experience, AI-assisted
        workflow, product ownership, and steady improvement of systems people
        rely on.
      </p>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-x-8 gap-y-7 sm:grid-cols-2 lg:grid-cols-3">
      {
        capabilities.map((capability) => (
          <article>
            <h3 class="font-semibold">{capability.title}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-65">
              {capability.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="grid grid-cols-1 gap-8 py-14 md:grid-cols-12 md:items-center md:py-16">
    <div class="md:col-span-8">
      <h2 class="text-3xl font-bold tracking-tight">
        Trusted by people I have worked with.
      </h2>
      <p class="mt-3 max-w-2xl leading-relaxed opacity-70">
        Recommendations from managers and colleagues highlight dependable
        delivery, adaptability, Microsoft-stack depth, communication, and a
        genuine interest in finding better solutions.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 md:col-span-4 md:justify-end">
      <a href="/recommendations" class="btn btn-outline">
        Read Recommendations
      </a>
    </div>
  </section>

  <section class="rounded-2xl border border-primary/30 bg-primary/10 p-7 md:flex md:items-center md:justify-between md:gap-8 md:p-9">
    <div>
      <h2 class="text-3xl font-bold tracking-tight">Let's talk.</h2>
      <p class="mt-3 max-w-2xl leading-relaxed opacity-75">
        Get in touch to discuss software engineering, fintech and payment
        platforms, Azure cloud systems, legacy modernisation, integrations, SaaS
        products, or developer tooling.
      </p>
    </div>
    <a href="/contact" class="btn btn-primary mt-6 shrink-0 md:mt-0">
      Contact me
    </a>
  </section>
</BaseLayout>
