---
import BaseLayout from "../layouts/BaseLayout.astro";

const proofPoints = [
  {
    value: "20+",
    label: "Years in software",
    detail: "From long-lived platforms to modern cloud services.",
  },
  {
    value: "7",
    label: "Live SaaS products",
    detail: "Browser software actively available to real users.",
  },
  {
    value: "Production-first",
    label: "Engineering mindset",
    detail: "Secure, observable, resilient, and supportable by design.",
  },
];

const engineeringStrengths = [
  "Hosted checkout, tokenisation, 3-D Secure, and webhook-driven payment flows.",
  "Partner integrations across REST, SOAP, files, secure authentication, and asynchronous processing.",
  "Azure App Services, Functions, Queue Storage, SQL, Key Vault, and Application Insights.",
  "Incremental legacy-to-cloud modernisation without losing operational stability.",
];

const productStrengths = [
  "Product discovery, UX decisions, and focused solutions for everyday browser workflows.",
  "Chrome, Edge, and Chromium extensions with free and Pro capabilities.",
  "Licensing, device activation, release management, privacy-conscious design, and support.",
  "A short feedback loop between real usage, product decisions, and continuous improvement.",
];

const capabilities = [
  {
    title: "Fintech & Payments",
    description:
      "Secure payment flows with clear state transitions, recoverability, and auditability.",
  },
  {
    title: "Azure Cloud",
    description:
      "Pragmatic cloud services designed for visibility, reliability, and day-to-day operation.",
  },
  {
    title: "Integrations",
    description:
      "Contract-aware connections across APIs, callbacks, queues, and file exchanges.",
  },
  {
    title: "Reliability",
    description:
      "Retries, idempotency, correlation IDs, monitoring, and incident-focused debugging.",
  },
];
---

<BaseLayout
  title="Anh Bui | Senior Software Engineer"
  description="Senior software engineer specialising in .NET, Azure, fintech, payments, distributed systems, and SaaS product development."
  sideBarActiveItemID="home"
>
  <section class="grid grid-cols-1 gap-10 pb-12 pt-4 md:grid-cols-12 md:items-center md:pb-16 md:pt-10">
    <div class="md:col-span-8">
      <h1 class="text-5xl font-bold tracking-tight md:text-7xl">Anh Bui</h1>
      <p class="mt-4 max-w-3xl text-2xl font-semibold leading-tight opacity-90 md:text-4xl">
        Senior / Lead Software Engineer building reliable software for the real
        world.
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed opacity-75">
        More than 20 years of experience across .NET, Azure, fintech, payments,
        distributed systems, and legacy-to-cloud modernisation. I build
        business-critical services that stay clear and supportable under
        production pressure.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/products" class="btn btn-primary">Explore Products</a>
        <a href="/cv" class="btn btn-outline">View CV</a>
      </div>
      <div class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm opacity-65">
        <span>.NET & Azure</span>
        <span>Fintech & Payments</span>
        <span>Distributed Systems</span>
        <span>Product Engineering</span>
      </div>
    </div>

    <aside class="flex items-center gap-5 md:col-span-4 md:flex-col md:items-end md:text-right">
      <img
        src="/profile.png"
        alt="Anh Bui"
        class="h-28 w-28 rounded-full object-cover ring-1 ring-white/20 shadow-xl md:h-44 md:w-44"
        loading="eager"
      />
      <div>
        <div class="text-lg font-semibold">Based in the UK</div>
        <div class="mt-1 max-w-xs text-sm leading-relaxed opacity-65">
          Senior engineering depth with hands-on ownership from architecture to
          production support.
        </div>
      </div>
    </aside>
  </section>

  <section
    class="grid grid-cols-1 border-y border-base-300 md:grid-cols-3"
    aria-label="Engineering highlights"
  >
    {
      proofPoints.map((point) => (
        <article class="border-base-300 py-6 md:border-r md:px-6 md:first:pl-0 md:last:border-r-0">
          <div class="text-3xl font-bold text-primary">{point.value}</div>
          <h2 class="mt-2 font-semibold">{point.label}</h2>
          <p class="mt-2 max-w-sm text-sm leading-relaxed opacity-65">
            {point.detail}
          </p>
        </article>
      ))
    }
  </section>

  <section class="grid grid-cols-1 gap-12 border-b border-base-300 py-14 md:grid-cols-2 md:gap-16 md:py-20">
    <article>
      <div class="text-sm font-semibold uppercase tracking-widest text-primary">
        Engineering depth
      </div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        Complex systems, made operationally clear.
      </h2>
      <p class="mt-4 leading-relaxed opacity-75">
        I specialise in integration-heavy platforms where reliability,
        security, and traceability are part of the architecture. My approach is
        pragmatic: understand the failure modes, make state explicit, and build
        observability in from day one.
      </p>
      <ul class="mt-6 space-y-3">
        {
          engineeringStrengths.map((strength) => (
            <li class="flex gap-3 text-sm leading-relaxed opacity-80">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="mt-0.5 h-5 w-5 shrink-0 fill-primary"
                aria-hidden="true"
              >
                <path d="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" />
              </svg>
              <span>{strength}</span>
            </li>
          ))
        }
      </ul>
    </article>

    <article>
      <div class="text-sm font-semibold uppercase tracking-widest text-primary">
        Products in production
      </div>
      <h2 class="mt-3 text-3xl font-bold tracking-tight">
        I build and operate my own SaaS products.
      </h2>
      <p class="mt-4 leading-relaxed opacity-75">
        Alongside professional engineering work, I run a growing collection of
        browser products used by real people. They turn engineering decisions
        into a complete product lifecycle: delivery, operation, feedback, and
        improvement.
      </p>
      <ul class="mt-6 space-y-3">
        {
          productStrengths.map((strength) => (
            <li class="flex gap-3 text-sm leading-relaxed opacity-80">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                class="mt-0.5 h-5 w-5 shrink-0 fill-primary"
                aria-hidden="true"
              >
                <path d="M9,16.17L4.83,12L3.41,13.41L9,19L21,7L19.59,5.59L9,16.17Z" />
              </svg>
              <span>{strength}</span>
            </li>
          ))
        }
      </ul>
      <a
        href="/products"
        class="mt-7 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
      >
        Explore 7 live products
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          class="h-4 w-4 fill-current"
          aria-hidden="true"
        >
          <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
        </svg>
      </a>
    </article>
  </section>

  <section class="border-b border-base-300 py-14 md:py-16">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-bold tracking-tight">What I bring</h2>
      <p class="mt-3 leading-relaxed opacity-70">
        Technical leadership grounded in delivery, production support, and
        steady improvement of the systems people rely on.
      </p>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-x-8 gap-y-7 sm:grid-cols-2 lg:grid-cols-4">
      {
        capabilities.map((capability) => (
          <article>
            <h3 class="font-semibold">{capability.title}</h3>
            <p class="mt-2 text-sm leading-relaxed opacity-65">
              {capability.description}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="grid grid-cols-1 gap-8 py-14 md:grid-cols-12 md:items-center md:py-16">
    <div class="md:col-span-8">
      <h2 class="text-3xl font-bold tracking-tight">
        Trusted by people I have worked with.
      </h2>
      <p class="mt-3 max-w-2xl leading-relaxed opacity-70">
        Recommendations from managers and colleagues highlight dependable
        delivery, adaptability, Microsoft-stack depth, communication, and a
        genuine interest in building better solutions.
      </p>
    </div>
    <div class="flex flex-wrap gap-3 md:col-span-4 md:justify-end">
      <a href="/recommendations" class="btn btn-outline">
        Read Recommendations
      </a>
    </div>
  </section>

  <section class="rounded-2xl border border-primary/30 bg-primary/10 p-7 md:flex md:items-center md:justify-between md:gap-8 md:p-9">
    <div>
      <h2 class="text-3xl font-bold tracking-tight">Let's talk.</h2>
      <p class="mt-3 max-w-2xl leading-relaxed opacity-75">
        Get in touch to discuss software engineering, fintech and payment
        platforms, Azure cloud systems, or SaaS product development.
      </p>
    </div>
    <a href="/contact" class="btn btn-primary mt-6 shrink-0 md:mt-0">
      Contact me
    </a>
  </section>
</BaseLayout>
